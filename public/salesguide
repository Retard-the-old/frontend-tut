<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Earn With Tutorii — Handbook</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,500;1,9..144,500&display=swap');

:root{
  --ink:#0A1628;
  --ink-soft:#1F2D44;
  --accent:#1E5BFF;
  --accent-soft:#4D82FF;
  --gold:#D4A574;
  --gold-soft:#F4E4CC;
  --gold-deep:#8B6332;
  --mist:#F5F7FB;
  --cream:#FAF7F2;
  --line:#E4E9F2;
  --success:#00B87A;
  --paper:#FFFFFF;
}

*,*::before,*::after{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  font-weight:400;
  line-height:1.65;
  color:var(--ink-soft);
  background:#EEF1F6;
  -webkit-font-smoothing:antialiased;
  font-feature-settings:"ss01","cv11";
}

/* PAGE — A4 portrait. 210mm x 297mm. */
.page{
  position:relative;
  width:210mm;
  min-height:297mm;
  margin:24px auto;
  background:var(--paper);
  color:var(--ink-soft);
  overflow:hidden;
  page-break-after:always;
  break-after:page;
  box-shadow:0 24px 64px rgba(10,22,40,0.12), 0 2px 8px rgba(10,22,40,0.06);
}
.page:last-of-type{page-break-after:auto;}
.page-inner{
  position:relative;
  z-index:2;
  padding:22mm 18mm;
}
.page--dark{background:var(--ink);color:#E8EEF8;}
.page--mist{background:linear-gradient(165deg,#F5F7FB 0%,#EDF1F8 50%,#E6ECF6 100%);}
.page--cream{background:linear-gradient(165deg,#FAF7F2 0%,#F5EFE3 60%,#F1E8D4 100%);}
.page--gold-tint{background:linear-gradient(180deg, #FBF5EA 0%, #FAF7F2 100%);}

/* Backgrounds layer — absolute, behind .page-inner */
.bg{position:absolute;inset:0;z-index:1;pointer-events:none;}
.bg svg{width:100%;height:100%;display:block;}

/* Typography */
h1,h2,h3,h4,h5{margin:0;color:var(--ink);font-weight:700;letter-spacing:-0.02em;line-height:1.15;}
.page--dark h1,.page--dark h2,.page--dark h3,.page--dark h4{color:#fff;}
p{margin:0 0 1em 0;}
strong{color:var(--ink);font-weight:600;}
.page--dark strong{color:#fff;}

.eyebrow{
  font-size:0.72rem;
  font-weight:600;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--accent);
  margin:0 0 14px 0;
  display:inline-block;
}
.eyebrow--gold{color:var(--gold-deep);}
.eyebrow--white{color:#9DB4DE;}

.deck{
  font-size:1.125rem;
  color:var(--ink-soft);
  max-width:62ch;
  margin:0 0 28px 0;
  line-height:1.55;
}
.page--dark .deck{color:#B8C7E0;}

h1.section-title{font-size:2.3rem;font-weight:700;margin:0 0 8px 0;letter-spacing:-0.025em;}
h2.section-title{font-size:1.95rem;font-weight:700;margin:0 0 8px 0;letter-spacing:-0.022em;}
h3.block-title{font-size:1.35rem;font-weight:700;margin:0 0 14px 0;letter-spacing:-0.015em;}
h4.mini-title{font-size:0.95rem;font-weight:700;color:var(--ink);margin:0 0 8px 0;letter-spacing:-0.005em;}

.num-tabular{font-variant-numeric:tabular-nums;font-weight:600;}

.fr-quote{font-family:'Fraunces',serif;font-style:italic;font-weight:500;letter-spacing:-0.01em;}

/* PILLS */
.pill{
  display:inline-flex;align-items:center;
  border-radius:999px;
  padding:6px 14px;
  font-size:0.78rem;font-weight:600;letter-spacing:0.04em;
  line-height:1.2;
  white-space:nowrap;
  font-variant-numeric:tabular-nums;
}
.pill--blue{background:rgba(30,91,255,0.08);color:var(--accent);border:1px solid rgba(30,91,255,0.2);}
.pill--gold{background:var(--gold-soft);color:var(--gold-deep);border:1px solid rgba(212,165,116,0.35);}
.pill--dark{background:var(--ink);color:#fff;border:1px solid var(--ink);}
.pill--success{background:rgba(0,184,122,0.1);color:var(--success);border:1px solid rgba(0,184,122,0.25);}
.pill--ghost{background:transparent;color:var(--ink-soft);border:1px solid var(--line);}
.pill--white{background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.25);}

/* GLOW LINE */
.glow{
  position:relative;
  height:1px;
  width:60%;
  margin:24px auto;
  background:linear-gradient(90deg,transparent 0%,var(--accent) 50%,transparent 100%);
}
.glow::before{
  content:"";position:absolute;inset:-3px 0;
  background:linear-gradient(90deg,transparent 0%,var(--accent) 50%,transparent 100%);
  filter:blur(6px);opacity:0.7;
}
.glow--gold{background:linear-gradient(90deg,transparent 0%,var(--gold) 50%,transparent 100%);}
.glow--gold::before{background:linear-gradient(90deg,transparent 0%,var(--gold) 50%,transparent 100%);}
.glow--full{width:100%;}
.glow--narrow{width:30%;}

/* CARDS */
.card{
  background:#fff;
  border:1px solid var(--line);
  border-radius:20px;
  padding:32px;
  box-shadow:0 1px 3px rgba(10,22,40,0.04), 0 12px 32px rgba(10,22,40,0.06);
  page-break-inside:avoid;
}
.card--tight{padding:24px;}
.card--flush{padding:0;overflow:hidden;}

/* CALLOUT */
.callout{
  border-radius:16px;
  padding:22px 26px;
  margin:18px 0;
  border-left:3px solid var(--gold);
  background:var(--gold-soft);
  color:var(--ink);
  page-break-inside:avoid;
}
.callout--blue{background:rgba(30,91,255,0.06);border-left-color:var(--accent);}
.callout--success{background:rgba(0,184,122,0.07);border-left-color:var(--success);}
.callout--dark{background:var(--ink);color:#E8EEF8;border-left-color:var(--gold);}
.callout--dark strong{color:#fff;}
.callout-label{
  display:block;
  font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--gold-deep);margin-bottom:6px;
}
.callout--blue .callout-label{color:var(--accent);}
.callout--success .callout-label{color:var(--success);}
.callout--dark .callout-label{color:var(--gold);}
.callout p:last-child{margin-bottom:0;}

/* GRADIENT NUMBER */
.gnum{
  font-weight:800;
  letter-spacing:-0.04em;
  line-height:0.95;
  background:linear-gradient(135deg,var(--accent) 0%,var(--accent-soft) 100%);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;color:transparent;
  font-variant-numeric:tabular-nums;
}
.gnum--gold{
  background:linear-gradient(135deg,var(--gold) 0%, #EBC893 50%, #B8915C 100%);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;color:transparent;
}

/* GRID UTILITIES */
.grid{display:grid;gap:24px;}
.grid-2{grid-template-columns:1fr 1fr;}
.grid-3{grid-template-columns:repeat(3,1fr);}
.grid-4{grid-template-columns:repeat(4,1fr);}
.flex{display:flex;}
.flex-row{display:flex;align-items:center;gap:12px;}
.flex-wrap{flex-wrap:wrap;}
.gap-8{gap:8px;} .gap-12{gap:12px;} .gap-16{gap:16px;} .gap-24{gap:24px;}
.mt-8{margin-top:8px;} .mt-16{margin-top:16px;} .mt-24{margin-top:24px;} .mt-32{margin-top:32px;} .mt-48{margin-top:48px;}
.mb-8{margin-bottom:8px;} .mb-16{margin-bottom:16px;} .mb-24{margin-bottom:24px;} .mb-32{margin-bottom:32px;}
.text-sm{font-size:0.88rem;}
.text-xs{font-size:0.78rem;}
.text-micro{font-size:0.68rem;letter-spacing:0.08em;text-transform:uppercase;font-weight:600;color:#7A8AA6;}
.center{text-align:center;}
.muted{color:#5C6B85;}
.page--dark .muted{color:#9DB4DE;}

/* CUSTOM BULLETS */
ul.bullets{list-style:none;padding:0;margin:0;}
ul.bullets li{position:relative;padding-left:26px;margin-bottom:10px;line-height:1.5;}
ul.bullets li::before{
  content:"";position:absolute;left:6px;top:10px;
  width:6px;height:6px;background:var(--accent);transform:rotate(45deg);
}
ul.bullets--gold li::before{background:var(--gold);}
ul.bullets--check li::before{
  content:"";left:0;top:7px;width:14px;height:14px;border-radius:50%;
  background:var(--gold-soft);border:1px solid var(--gold);transform:none;
}
ul.bullets--check li::after{
  content:"";position:absolute;left:4px;top:11px;width:6px;height:3px;
  border-left:1.5px solid var(--gold-deep);border-bottom:1.5px solid var(--gold-deep);
  transform:rotate(-45deg);
}
ul.bullets--chev li::before{
  content:"";left:4px;top:8px;width:7px;height:7px;background:transparent;
  border-right:1.5px solid var(--accent);border-top:1.5px solid var(--accent);
  transform:rotate(45deg);
}
ol.steps{list-style:none;padding:0;margin:0;counter-reset:s;}
ol.steps li{position:relative;padding-left:38px;margin-bottom:14px;counter-increment:s;line-height:1.55;}
ol.steps li::before{
  content:counter(s);position:absolute;left:0;top:1px;
  width:24px;height:24px;border-radius:50%;
  background:var(--ink);color:#fff;
  font-size:0.72rem;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  font-variant-numeric:tabular-nums;
}

/* TABLES */
table.tbl{width:100%;border-collapse:collapse;font-size:0.92rem;}
table.tbl th{
  text-align:left;padding:12px 14px;
  font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  color:#5C6B85;border-bottom:1px solid var(--line);
}
table.tbl td{padding:14px;border-bottom:1px solid var(--line);vertical-align:top;line-height:1.5;}
table.tbl tr:last-child td{border-bottom:none;}
table.tbl td.num{font-variant-numeric:tabular-nums;font-weight:600;color:var(--ink);}

/* CHAT BUBBLES */
.chat{
  background:#ECEFF4;
  border-radius:14px;
  padding:18px 16px 14px;
  display:flex;flex-direction:column;gap:6px;
  position:relative;
  page-break-inside:avoid;
}
.chat-header{
  display:flex;align-items:center;gap:8px;
  font-size:0.7rem;color:#7A8AA6;font-weight:500;
  margin-bottom:4px;letter-spacing:0.04em;
}
.chat-header .dot{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,#B5C8DD,#8DA3C0);}
.bubble{
  max-width:78%;
  padding:10px 14px 8px;
  border-radius:14px;
  font-size:0.86rem;
  line-height:1.5;
  color:var(--ink);
  /* Avoid breaking a bubble across two PDF pages */
  page-break-inside:avoid;
  break-inside:avoid;
}
.bubble--out{
  background:#DCEFD1;
  align-self:flex-end;
  border-bottom-right-radius:4px;
}
.bubble--in{
  background:#fff;
  align-self:flex-start;
  border-bottom-left-radius:4px;
  box-shadow:0 1px 1px rgba(10,22,40,0.05);
}
/* Timestamp: floats to the bottom-right of the bubble so message text
   wraps cleanly around it instead of being overlapped by it. */
.bubble .ts{
  float:right;
  margin:6px 0 0 10px;
  padding-top:2px;
  font-size:0.62rem;color:#8B9DB0;font-weight:500;
  font-variant-numeric:tabular-nums;
  white-space:nowrap;
}
/* Clear the float so the next bubble doesn't ride up next to a ts */
.bubble::after{content:"";display:block;clear:both;}

/* CONVERSATION FLOW DIAGRAM */
.flow{display:flex;flex-direction:column;align-items:center;gap:0;}
.flow-node{
  width:100%;max-width:380px;
  border-radius:16px;
  padding:14px 18px 16px;
  position:relative;
  page-break-inside:avoid;
}
.flow-node--agent{
  background:rgba(30,91,255,0.06);
  border:1px solid rgba(30,91,255,0.35);
}
.flow-node--prospect{
  background:var(--mist);
  border:1px solid var(--line);
}
.flow-node--close{
  background:var(--gold-soft);
  border:1px solid var(--gold);
}
.flow-label{
  display:inline-block;
  font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  padding:3px 9px;border-radius:999px;
  margin-bottom:8px;
}
.flow-node--agent .flow-label{background:rgba(30,91,255,0.12);color:var(--accent);}
.flow-node--prospect .flow-label{background:var(--ink);color:#fff;}
.flow-node--close .flow-label{background:var(--gold);color:#fff;}
.flow-node-text{font-size:0.82rem;line-height:1.4;color:var(--ink);font-weight:500;}
.flow-arrow{
  width:1.5px;height:22px;background:var(--accent);
  position:relative;flex-shrink:0;
}
.flow-arrow::after{
  content:"";position:absolute;bottom:-1px;left:50%;
  width:8px;height:8px;border-right:1.5px solid var(--accent);border-bottom:1.5px solid var(--accent);
  transform:translateX(-50%) rotate(45deg);
}
.flow-arrow--gold{background:var(--gold);}
.flow-arrow--gold::after{border-color:var(--gold);}

/* COVER specifics */
.cover-wordmark{
  font-weight:800;letter-spacing:0.3em;font-size:0.92rem;color:#fff;
}
.cover-title{
  font-size:4.2rem;font-weight:600;letter-spacing:-0.035em;line-height:1.0;color:#fff;
}
.cover-tagline{
  font-family:'Fraunces',serif;font-style:italic;font-weight:500;
  font-size:1.4rem;color:#B8C7E0;max-width:18em;line-height:1.4;
}

/* iPhone mockup — modern edge-to-edge screen, hairline bezel */
.iphone{
  width:170px;
  aspect-ratio:170/348;
  border-radius:30px;
  background:var(--ink);
  padding:3px;
  position:relative;
  box-shadow:0 20px 40px rgba(10,22,40,0.18), 0 2px 6px rgba(10,22,40,0.1);
  flex-shrink:0;
}
.p10-mocks .iphone{ width:148px; padding:2.5px; }
.iphone-screen{
  width:100%;height:100%;
  border-radius:27px;
  overflow:hidden;
  position:relative;
  background:#0F1A2E;
}
.p10-mocks .iphone-screen{ border-radius:27.5px; }
.iphone-island{
  position:absolute;top:8px;left:50%;transform:translateX(-50%);
  width:54px;height:14px;border-radius:999px;background:#000;z-index:5;
}

/* Small util */
.spread{display:flex;align-items:center;justify-content:space-between;gap:16px;}

/* All animations removed — this document is print/PDF first */

/* Print */
@page { size: A4; margin: 0; }
@media print{
  body{background:#fff;}
  .page{margin:0;box-shadow:none;page-break-after:always;break-after:page;}
  .card,.callout,.flow-node,.chat{page-break-inside:avoid;}
}

/* ========================================================
   MOOD : Editorial   (Fraunces titles, ivory paper, hairline)
   ======================================================== */
body.mood-editorial{
  background:#EFEAE0;
}
body.mood-editorial .page{
  background:#F8F4EA;
  box-shadow:0 1px 0 rgba(60,40,20,.08), 0 22px 60px rgba(60,40,20,.10);
}
body.mood-editorial .page--dark{
  background:#1A1612;color:#EBE3D1;
}
body.mood-editorial .page--mist,
body.mood-editorial .page--cream{
  background:#F8F4EA;
}
body.mood-editorial h1,
body.mood-editorial h2,
body.mood-editorial h3,
body.mood-editorial .cover-title,
body.mood-editorial .section-title{
  font-family:'Fraunces',serif;
  font-weight:500;
  letter-spacing:-0.018em;
}
body.mood-editorial .cover-title{font-weight:400;font-style:italic;}
body.mood-editorial .eyebrow{
  font-family:'Fraunces',serif;
  font-style:italic;
  font-weight:500;
  letter-spacing:0.06em;
  text-transform:none;
  color:#7A6248;
}
body.mood-editorial .eyebrow--gold{color:#7A6248;}
body.mood-editorial .eyebrow--white{color:#D9C9A6;}
body.mood-editorial .eyebrow::before{display:none;}
body.mood-editorial .deck{font-family:'Fraunces',serif;font-style:italic;font-weight:400;color:#5C4A36;}
body.mood-editorial .page--dark .deck{color:#C9B894;}
body.mood-editorial{--ink:#2A2218;--ink-soft:#4A3D2C;--paper:#F8F4EA;--line:#E0D8C5;}
body.mood-editorial strong{color:#2A2218;}
body.mood-editorial .glow,
body.mood-editorial .glow--gold{
  background:linear-gradient(90deg,transparent 0%,#9A7D54 50%,transparent 100%) !important;
  height:1px;opacity:.65;
}
body.mood-editorial .glow::before{display:none;}
body.mood-editorial .pill{border-radius:2px;}

/* ========================================================
   MOOD : Print       (newspaper, hairlines, no mesh, no skyline)
   ======================================================== */
body.mood-print{
  background:#E8E5DD;
}
body.mood-print .page{
  background:#FBFAF6;
  box-shadow:0 0 0 1px #DDD8CC;
}
body.mood-print .page--dark{
  background:#1A1A1A;color:#E8E5DD;
}
body.mood-print .page--mist,
body.mood-print .page--cream{background:#FBFAF6;}
body.mood-print{--ink:#1A1A1A;--ink-soft:#2A2A2A;--accent:#1A1A1A;--accent-soft:#3A3A3A;--gold:#6B5836;--gold-soft:#E8DEC8;--gold-deep:#3A2E1A;--line:#C9C2B0;}
body.mood-print h1,body.mood-print h2,body.mood-print h3,body.mood-print h4{
  font-family:'Fraunces',serif;font-weight:600;letter-spacing:-0.015em;
}
body.mood-print .cover-title{font-family:'Fraunces',serif;font-weight:500;}
body.mood-print .eyebrow{
  border-top:1px solid #1A1A1A;
  padding-top:6px;
  letter-spacing:0.32em;
  color:#1A1A1A;
}
body.mood-print .eyebrow::before{display:none;}
body.mood-print .deck{color:#3A3A3A;}
body.mood-print .glow,
body.mood-print .glow--gold{
  background:#1A1A1A !important;height:1px;opacity:1;
}
body.mood-print .glow::before{display:none;}
body.mood-print .card,
body.mood-print .callout,
body.mood-print .flow-node{
  border-radius:0 !important;
  box-shadow:none !important;
  border:1px solid #1A1A1A !important;
}
body.mood-print .pill{border-radius:0;border:1px solid currentColor;}
body.mood-print .bubble{border-radius:2px !important;}

/* ========================================================
   DENSITY (set by JS as --density-scale & --density-pad)
   ======================================================== */
body{--density-scale:1;--density-pad:1;}
.page-inner{padding: calc(22mm * var(--density-pad)) calc(18mm * var(--density-pad));}
body{font-size: calc(16px * var(--density-scale));}

/* ========================================================
   FOLIO (page numbers)
   ======================================================== */
.folio{
  position:absolute;
  bottom:14mm;
  font-family:'Inter',sans-serif;
  font-size:0.62rem;
  font-weight:600;
  letter-spacing:0.28em;
  color:#5C6B85;
  text-transform:uppercase;
  pointer-events:none;
  display:flex;
  align-items:center;
  gap:10px;
}
.folio .folio-rule{
  width:18mm;height:1px;background:currentColor;opacity:.45;
}
.folio--right{right:18mm;flex-direction:row-reverse;}
.folio--left{left:18mm;}
.page--dark .folio{color:#9DB4DE;}
body.mood-editorial .folio{
  font-family:'Fraunces',serif;font-style:italic;font-weight:400;
  letter-spacing:0.05em;text-transform:none;color:#7A6248;font-size:0.78rem;
}
body.mood-editorial .page--dark .folio{color:#C9B894;}
body.mood-editorial .folio .folio-rule{display:none;}
body.mood-print .folio{
  font-family:'Fraunces',serif;font-weight:500;letter-spacing:0.18em;color:#1A1A1A;font-size:0.66rem;
}
body.mood-print .page--dark .folio{color:#E8E5DD;}

/* ========================================================
   TABLE OF CONTENTS
   ======================================================== */
.toc-wrap{display:block;}
.toc-group{margin-bottom:22px;}
.toc-group-label{
  font-family:'Inter',sans-serif;
  font-size:0.66rem;font-weight:600;letter-spacing:0.32em;text-transform:uppercase;
  color:#8B6332;margin-bottom:10px;padding-bottom:6px;
  border-bottom:1px solid var(--line);
  display:flex;justify-content:space-between;align-items:baseline;
}
.toc-group-label .toc-group-num{
  font-family:'Fraunces',serif;font-style:italic;font-weight:400;
  letter-spacing:0;text-transform:none;color:#5C6B85;font-size:0.85rem;
}
.toc-row{
  display:grid;
  grid-template-columns: auto 1fr auto;
  align-items:baseline;
  gap:12px;
  padding:7px 0;
  font-size:0.95rem;
}
.toc-row + .toc-row{border-top:1px dotted #D8DEEA;}
.toc-row-num{
  font-family:'Fraunces',serif;font-style:italic;font-weight:400;
  color:#8B6332;font-size:0.78rem;
  min-width:1.6em;
}
.toc-row-title{color:var(--ink);font-weight:500;letter-spacing:-0.005em;}
